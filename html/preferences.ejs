<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Preferences</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="bg-light">

  <div class="container py-5">
    <h2 class="text-center mb-4">Edit Your Preferences</h2>

    <form method="POST" action="/dashboard/preferences" class="mx-auto" style="max-width: 500px; background-color: #fffaf6; padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.05);">

      <div class="mb-3">
        <label for="fontSize" class="form-label">Font Size</label>
        <input type="number" class="form-control" id="fontSize" name="fontSize" min="10" max="40" value="<%= profile.preferences.fontSize %>">
      </div>

      <div class="mb-3">
        <label for="fontColor" class="form-label">Font Color</label>
        <input type="color" class="form-control form-control-color" id="fontColor" name="fontColor" value="<%= profile.preferences.fontColor %>">
      </div>

      <div class="mb-3">
        <label for="fontFamily" class="form-label">Font Family</label>
        <select class="form-select" id="fontFamily" name="fontFamily">
          <option value="Arial" <%= profile.preferences.fontFamily === 'Arial' ? 'selected' : '' %>>Arial</option>
          <option value="Times New Roman" <%= profile.preferences.fontFamily === 'Times New Roman' ? 'selected' : '' %>>Times New Roman</option>
          <option value="Verdana" <%= profile.preferences.fontFamily === 'Verdana' ? 'selected' : '' %>>Verdana</option>
        </select>
      </div>

      <div class="mb-3">
        <label for="noteBackground" class="form-label">Note Background</label>
        <input type="color" class="form-control form-control-color" id="noteBackground" name="noteBackground" value="<%= profile.preferences.noteBackground %>">
      </div>

      <div class="text-center">
        <button type="submit" class="btn btn-success px-4">Save</button>
        <a href="/dashboard" class="btn btn-secondary ms-2">Cancel</a>
      </div>
    </form>
  </div>

</body>
</html>
