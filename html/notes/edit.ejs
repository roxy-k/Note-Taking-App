<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Note</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body style="font-family: <%= profile?.preferences?.fontFamily || 'Arial' %>;
             font-size: <%= profile?.preferences?.fontSize || 16 %>px;
             background-color: <%= profile?.preferences?.noteBackground || '#ffffff' %>;
             color: <%= profile?.preferences?.fontColor || '#000000' %>;">
  
  <div class="container py-5">
    <h1 class="mb-4">✏️ Edit Note</h1>

    <form method="POST" action="/notes/<%= note._id %>/edit">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" id="title" name="title" class="form-control" value="<%= note.title %>" required>
      </div>

      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <input type="text" id="category" name="category" class="form-control" value="<%= note.category %>">
      </div>

      <div class="mb-3">
        <label for="content" class="form-label">Content</label>
        <textarea id="content" name="content" rows="8" class="form-control" required><%= note.content %></textarea>
      </div>

      <button type="submit" class="btn btn-primary">💾 Save Changes</button>
      <a href="/notes/<%= note._id %>" class="btn btn-secondary ms-2">Cancel</a>
    </form>
  </div>
</body>
</html>
