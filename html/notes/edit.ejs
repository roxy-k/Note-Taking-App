<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Note</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="font-family: <%= profile?.preferences?.fontFamily || 'Arial' %>; 
             background-color: <%= profile?.preferences?.noteBackground || '#ffffff' %>; 
             color: <%= profile?.preferences?.fontColor || '#000000' %>;">

  
  <h1>Edit Note</h1>

  <form action="/notes/<%= note._id %>/edit" method="POST">
    <label>Title:</label>
    <input type="text" name="title" value="<%= note.title %>" required>

    <label>Content:</label>
    <textarea name="content" rows="8" required><%= note.content %></textarea>

    <label>Category:</label>
    <input type="text" name="category" value="<%= note.category %>">

    <button type="submit" class="btn">Save Changes</button>
  </form>

  <br>
  <a href="/notes/<%= note._id %>" class="btn">Cancel</a>
</body>
</html>
