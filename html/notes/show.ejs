<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= note.title %> | My Notes</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body style="font-family: <%= profile?.preferences?.fontFamily || 'Arial' %>;
             font-size: <%= profile?.preferences?.fontSize || 16 %>px;
             background-color: <%= profile?.preferences?.noteBackground || '#ffffff' %>;
             color: <%= profile?.preferences?.fontColor || '#000000' %>;">

  <h1><%= note.title %></h1>

  <p><strong>Category:</strong> <%= note.category || 'Uncategorized' %></p>
  <p><%= note.content %></p>

  <a href="/notes/<%= note._id %>/edit" class="btn">Edit</a>

  <form action="/notes/<%= note._id %>/delete" method="POST" style="display:inline;">
    <button type="submit" class="btn delete-btn" onclick="return confirm('Are you sure you want to delete this note?');">Delete</button>
  </form>

  <br><br>
  <a href="/notes" class="btn">Back to Notes</a>
</body>
</html>
